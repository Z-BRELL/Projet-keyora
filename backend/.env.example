# ══════════════════════════════════════════════════════════════════════════
# ENV DE PRODUCTION — service.keyora.org (derrière nginx + Let's Encrypt)
# ══════════════════════════════════════════════════════════════════════════

# ─── PostgreSQL (utilisé par le service "postgres" du docker-compose) ───────
POSTGRES_USER=keyora
POSTGRES_PASSWORD=KnllEbn8fIOWykvzaeDW2lrp
POSTGRES_DB=keyora
# Note: DATABASE_URL est construit automatiquement par docker-compose.yml
# à partir des 3 variables ci-dessus (host = postgres, port = 5432).
# Inutile de le définir ici pour un déploiement via docker compose.
#
# ⚠️ Si une base existe déjà avec l'ancien mot de passe (phase de test),
# changer cette valeur ici NE suffit PAS : Postgres ne relit ce mot de passe
# qu'à la toute première initialisation du volume. Voir l'étape dédiée dans
# le guide de déploiement pour le faire correctement (ALTER USER ou reset volume).

# ─── App ─────────────────────────────────────────────────────────────────
# production = cookies "secure" (HTTPS obligatoire, on l'a via nginx+certbot)
# + vérification email réellement appliquée (plus d'auto-verify comme en dev).
NODE_ENV=production
PORT=4000
FRONTEND_URL=https://keyora.org

# ─── JWT (secrets régénérés pour la prod, à ne jamais réutiliser ceux du staging) ─
JWT_SECRET=563f89321b40b30b82eab97d3cc920aa6ee9e31a7e625a463ac9509f998429b3
JWT_REFRESH_SECRET=9258c9d0c46e2716abfbea0565253fb29af4a5acc3563e30976a5258e699bb05

# ─── SMTP (envoi d'emails) ────────────────────────────────────────────────
# Nécessaire en prod (reset password, vérification email) : renseigner un vrai
# compte SMTP (ex: SES, Mailgun, Sendgrid, ou un compte SMTP classique).
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=Keyora <no-reply@keyora.org>

# ─── AWS S3 (upload de médias — photos de listings) ───────────────────────
# Même bucket/CDN que sur le projet cherix-api : réutilise les mêmes valeurs.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=
AWS_S3_BUCKET=
# Préfixe optionnel dans le bucket (ex: "keyora/" pour séparer des autres projets
# qui partagent le même bucket). Laisser vide si non nécessaire.
AWS_S3_KEY_PREFIX=
# URL de base du CDN (CloudFront) servant ce bucket, sans slash final
# (ex: https://cdn.exemple.com) — utilisée pour construire l'URL publique des photos.
AWS_CDN_URL=
