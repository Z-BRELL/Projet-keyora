# ══════════════════════════════════════════════════════════════════════════
# ENV DE TEST / STAGING (pas de prod, pas encore de domaine — accès via IP:PORT)
# ══════════════════════════════════════════════════════════════════════════

# ─── PostgreSQL (utilisé par le service "postgres" du docker-compose) ───────
POSTGRES_USER=keyora
POSTGRES_PASSWORD=4kOqfiC6p2qlJhXe61rTacbA
POSTGRES_DB=keyora
# Note: DATABASE_URL est construit automatiquement par docker-compose.yml
# à partir des 3 variables ci-dessus (host = postgres, port = 5432).
# Inutile de le définir ici pour un déploiement via docker compose.

# ─── App ─────────────────────────────────────────────────────────────────
# development = cookies envoyés sans HTTPS (nécessaire tant qu'il n'y a pas
# de domaine/certificat) + comptes auto-vérifiés pour faciliter les tests.
NODE_ENV=development
PORT=4000
# Pas de domaine pour l'instant : remplace par http://<IP_PUBLIQUE_SERVEUR>:3000
# si un frontend est déployé sur le même serveur, sinon laisse localhost.
FRONTEND_URL=http://localhost:3000

# ─── JWT (secrets générés aléatoirement, à régénérer avant tout passage en prod) ─
JWT_SECRET=e064de045ec0c8ce58aeac03dd469bfdb015f5cd626ad588fad5c746ca86bcea
JWT_REFRESH_SECRET=43810ee5846f2f98234aa7179338e1dcaa24ee35326f57830b7e995218b1f617

# ─── SMTP (envoi d'emails) ────────────────────────────────────────────────
# Pas de vrai compte SMTP à ce stade : laissé vide, l'envoi d'email échouera
# silencieusement (n'empêche pas le reste de l'API de fonctionner).
# Pour tester rapidement, utilise un compte gratuit https://mailtrap.io
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=Keyora <no-reply@keyora.local>

# ─── Cloudinary (upload de médias) ────────────────────────────────────────
# Nécessite un vrai compte (gratuit) sur https://cloudinary.com — laissé vide
# tant que tu ne l'as pas créé, l'upload de médias ne fonctionnera pas.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
