# ══════════════════════════════════════════════════════════════════════════
# ENV DE PROD — domaine keyora.org derrière Nginx + Let's Encrypt
# ══════════════════════════════════════════════════════════════════════════

# URL PUBLIQUE du backend (celle que le navigateur de l'utilisateur appelle).
# ⚠️ Utilisé au moment du BUILD (docker compose build), pas au runtime :
# si tu la changes, il faut rebuild l'image (`docker compose build web`).
NEXT_PUBLIC_API_URL=https://service.keyora.org

# Port d'écoute du conteneur Next.js sur l'hôte Ubuntu.
# Le container n'est PAS exposé publiquement : Nginx (sur le même hôte)
# proxy en local vers ce port (voir docker-compose.yml -> 127.0.0.1:PORT).
PORT=3000
